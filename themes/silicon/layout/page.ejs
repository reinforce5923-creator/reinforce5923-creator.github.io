<%
  const pagePostCategory = page.post_category;
  const pagePostSectionTitle = page.post_section_title || '文章列表';
  const categoryPosts = pagePostCategory ? site.posts.filter(function(post) {
    const categories = post.categories
      ? (typeof post.categories.toArray === 'function' ? post.categories.toArray() : (post.categories.data || post.categories))
      : [];
    return categories.some(function(category) {
      return (category.name || category) === pagePostCategory;
    });
  }).sort('date', -1) : null;
%>

<article class="page">
  <header class="page-header">
    <h1><%= page.title %></h1>
  </header>
  <div class="article-content">
    <%- page.content %>
  </div>
  <% if (pagePostCategory) { %>
    <section class="page-posts">
      <h2><%= pagePostSectionTitle %></h2>
      <% if (categoryPosts.length) { %>
        <div class="post-list">
          <% categoryPosts.forEach(function(post) { %>
            <article class="post-item compact">
              <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'YYYY-MM-DD') %></time>
              <span class="post-card-views">点击量 --</span>
              <h3><a href="<%- url_for(post.path) %>"><%= post.title %></a></h3>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <p class="empty-state">这个栏目还没有文章。</p>
      <% } %>
    </section>
  <% } %>
</article>
