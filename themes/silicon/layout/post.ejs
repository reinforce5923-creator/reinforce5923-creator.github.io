<article class="article">
  <header class="article-header">
    <p class="article-meta">
      <time datetime="<%= date_xml(page.date) %>"><%= date(page.date, 'YYYY-MM-DD') %></time>
      <% if (page.categories && page.categories.length) { %>
        <span>/</span>
        <% page.categories.forEach(function(cat, i) { %>
          <a href="<%- url_for(cat.path) %>"><%= cat.name %></a><%= i < page.categories.length - 1 ? ', ' : '' %>
        <% }) %>
      <% } %>
    </p>
    <h1><%= page.title %></h1>
    <% if (page.tags && page.tags.length) { %>
      <div class="tag-row">
        <% page.tags.forEach(function(tag) { %><a href="<%- url_for(tag.path) %>"># <%= tag.name %></a><% }) %>
      </div>
    <% } %>
  </header>
  <div class="article-shell">
    <% if (page.toc !== false) { %>
      <aside class="toc">
        <strong>目录</strong>
        <%- toc(page.content, { list_number: false, max_depth: 3 }) %>
      </aside>
    <% } %>
    <div class="article-content">
      <%- page.content %>
    </div>
  </div>
  <nav class="post-nav">
    <% if (page.prev) { %><a href="<%- url_for(page.prev.path) %>">上一篇：<%= page.prev.title %></a><% } %>
    <% if (page.next) { %><a href="<%- url_for(page.next.path) %>">下一篇：<%= page.next.title %></a><% } %>
  </nav>
</article>
