<section class="page">
  <header class="page-header">
    <h1>分类：<%= page.category %></h1>
  </header>
  <div class="post-list">
    <% page.posts.sort('date', -1).forEach(function(post) { %>
      <article class="post-item compact">
        <div class="post-card-meta">
          <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'YYYY-MM-DD') %></time>
          <span class="post-card-views">点击量 <span data-post-view-counter data-counter-path="<%- url_for(post.path) %>">--</span></span>
        </div>
        <h2><a href="<%- url_for(post.path) %>"><%= post.title %></a></h2>
      </article>
    <% }) %>
  </div>
</section>
